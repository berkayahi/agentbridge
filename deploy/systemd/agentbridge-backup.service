[Unit]
Description=Back up and retain AgentBridge local data
ConditionPathExists=%h/.local/share/agentbridge/agentbridge.db

[Service]
Type=oneshot
UMask=0077
Environment=AGENTBRIDGE_DATA_DIR=%h/.local/share/agentbridge
EnvironmentFile=-%h/.config/agentbridge/backup.env
ExecStart=%h/.local/bin/agentbridge backup --database %h/.local/share/agentbridge/agentbridge.db --output %h/.local/share/agentbridge/backups
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
LockPersonality=true
RestrictSUIDSGID=true
ReadWritePaths=%h/.local/share/agentbridge %h/.cache/agentbridge
